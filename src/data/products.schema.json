{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductsList",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Product"
  },
  "definitions": {
    "Product": {
      "type": "object",
      "required": [
        "id",
        "name",
        "brand",
        "category",
        "price",
        "salePrice",
        "badge",
        "colors",
        "sizes",
        "image",
        "image2",
        "description",
        "isBestSeller",
        "isNew",
        "stock"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1,
          "description": "Mã định danh duy nhất của sản phẩm"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Tên hiển thị của sản phẩm giày"
        },
        "brand": {
          "type": "string",
          "enum": ["VANS", "CONVERSE"],
          "description": "Thương hiệu sản xuất"
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "description": "Dòng sản phẩm (phân loại chi tiết)"
        },
        "price": {
          "type": "integer",
          "minimum": 0,
          "description": "Giá niêm yết (VND)"
        },
        "salePrice": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Giá khuyến mãi (VND), hoặc null nếu không có giảm giá"
        },
        "badge": {
          "type": ["string", "null"],
          "enum": ["HOT", "SALE", "NEW", null],
          "description": "Nhãn trạng thái hiển thị trên giao diện (HOT, SALE, NEW hoặc null)"
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "minItems": 1,
          "description": "Danh sách các mã màu HEX của sản phẩm"
        },
        "sizes": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 30,
            "maximum": 50
          },
          "minItems": 1,
          "description": "Danh sách các kích thước giày khả dụng (theo size EU)"
        },
        "image": {
          "type": "string",
          "pattern": "^\\/images\\/.*\\.(png|jpe?g|webp)$",
          "description": "Đường dẫn tương đối tới ảnh đại diện chính của sản phẩm"
        },
        "image2": {
          "type": "string",
          "pattern": "^\\/images\\/.*\\.(png|jpe?g|webp)$",
          "description": "Đường dẫn tương đối tới ảnh phụ (ảnh khi hover chuột)"
        },
        "description": {
          "type": "string",
          "description": "Mô tả chi tiết về sản phẩm giày"
        },
        "isBestSeller": {
          "type": "boolean",
          "description": "Đánh dấu sản phẩm bán chạy"
        },
        "isNew": {
          "type": "boolean",
          "description": "Đánh dấu sản phẩm mới"
        },
        "stock": {
          "type": "integer",
          "minimum": 0,
          "description": "Số lượng sản phẩm còn trong kho"
        }
      }
    }
  }
}
